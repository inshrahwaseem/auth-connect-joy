# ─── Supabase ─────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API

# Your project's public URL
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Anon/public key — safe to expose in the browser
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key

# ─── Cloudflare Turnstile ─────────────────────────────────────────────────────
# Found in: Cloudflare Dashboard → Turnstile → your site
# The site key is public; the secret key goes in Supabase Edge Function secrets.

VITE_TURNSTILE_SITE_KEY=0x4AAAAAAAxxxxxxxxxxxxxxxxxxx

# ─── Supabase Edge Function Secrets ──────────────────────────────────────────
# Set these via: supabase secrets set KEY=value
# They are NOT prefixed with VITE_ — they are server-side only.
#
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   (set by Supabase automatically)
# TURNSTILE_SECRET_KEY=your-cloudflare-turnstile-secret
# ALLOWED_ORIGIN=https://your-domain.com            (set to * for local dev)
# RESEND_API_KEY=your-resend-api-key                (for email OTP sending)
